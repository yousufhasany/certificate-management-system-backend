# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/ai-cms

# JWT Secret (generate a strong random string for production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Server Port
PORT=5000

# Node Environment
NODE_ENV=development

# Firebase Admin (choose one approach)
# Option A: Service account file path
# FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/service-account.json

# Option B: JSON service account string
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Option C: Individual fields
# FIREBASE_PROJECT_ID=your-firebase-project-id
# FIREBASE_CLIENT_EMAIL=your-firebase-adminsdk@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"

# Option D: Application default credentials
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
